# LLM provider selection. Supported values: openai, anthropic.
LLM_PROVIDER=openai

# OpenAI credentials, used when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Anthropic credentials, used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Optional QA model override for the notebook/question path.
# OpenAI example: LLM_MODEL_QA=gpt-5.5
# Anthropic example: LLM_MODEL_QA=claude-sonnet-4-20250514
LLM_MODEL_QA=
